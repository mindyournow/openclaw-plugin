{
  "name": "@mind-your-now/myn",
  "version": "0.7.1",
  "description": "OpenClaw plugin for Mind Your Now - AI-powered task and life management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "prebuild": "node scripts/sync-skills.js",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "mind-your-now",
    "myn",
    "task-management",
    "ai",
    "agent"
  ],
  "author": "Mind Your Now <team@mindyournow.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mindyournow/openclaw-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/mindyournow/openclaw-plugin/issues"
  },
  "homepage": "https://github.com/mindyournow/openclaw-plugin#readme",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "openclaw": "^2026.2.22",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@mind-your-now/skills": "^0.1.0",
    "@sinclair/typebox": "^0.34.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills",
    "README.md",
    "LICENSE"
  ]
}
